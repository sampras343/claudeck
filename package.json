{
  "name": "claupilot",
  "version": "0.0.2",
  "description": "Interactive dashboard for monitoring and managing multiple Claude Code CLI instances",
  "type": "module",
  "bin": {
    "claupilot": "./bin/claupilot.js"
  },
  "files": [
    "bin/",
    "server/dist/",
    "server/scripts/",
    "client/dist/"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "cd client && npx vite --port 5173",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npx vite build",
    "build:server": "npx tsc -p server/tsconfig.json",
    "start": "node bin/claupilot.js",
    "test": "node --test --import tsx server/src/__tests__/*.test.ts",
    "test:ci": "node --test --import tsx --reporter spec server/src/__tests__/*.test.ts",
    "typecheck": "npx tsc --noEmit -p server/tsconfig.json && cd client && npx tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "dashboard",
    "terminal",
    "monitor",
    "cli",
    "ai",
    "anthropic"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sampras343/claupilot"
  },
  "license": "MIT",
  "dependencies": {
    "chokidar": "^5.0.0",
    "express": "^5.1.0",
    "minisearch": "^7.2.0",
    "uuid": "^14.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.0",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
